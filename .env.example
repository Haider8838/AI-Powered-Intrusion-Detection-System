# ============================================================
# AI-Powered IDS — API Keys Configuration
# ============================================================
# Copy this file to  .env  and fill in your key(s).
# The system works without any key — LLM explanations will
# use a built-in fallback template instead.
#
# Get Anthropic key: https://console.anthropic.com/
# Get Google key:    https://aistudio.google.com/apikey
# ============================================================

# Option A — Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Option B — Google Gemini
GOOGLE_API_KEY=your-google-api-key-here
